            elemento = int(input("Digite o valor para buscar: "))
            print(pilha.posicao(elemento))
        elif opcao == 4:
            print(pilha)
        elif opcao == 5:
            expressao = input("Insira a expressão: ")
            resultado = pilha.verifica_sintaxe(expressao)
            print(f"{expressao} : {resultado}")


