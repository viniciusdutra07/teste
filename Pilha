def main():
    tamanho = int(input("Tamanho máximo da pilha: "))
    pilha = Pilha(tamanho)
    opcao = 0

    while opcao != 5:
        print("1 - Inserir Elemento\n"
              "2 - Remover Elemento\n"
              "3 - Buscar Elemento\n"
              "4 - Imprimir pilha\n"
              "5 - Verifica sintaxe")
        opcao = int(input("opção: "))

        if opcao == 1:
            elemento = int(input("Digite o valor para inserir: "))
            try:
                pilha.insere(elemento)
            except IndexError as e:
                print(e)
        elif opcao == 2:
            try:
                valor = pilha.remove()
                print(f"Elemento removido: {valor}")
            except IndexError as e:
                print(e)
